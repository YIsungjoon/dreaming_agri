# Vercel Supabase integration / server-side access
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=YOUR_LOCAL_PUBLISHABLE_KEY

# Legacy projects may still expose an anon key instead.
# SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_KEY

# Browser-side access (add only when a client-side Supabase client is needed)
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_LOCAL_PUBLISHABLE_KEY_FROM_SUPABASE_START
